# ClawPunch Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED
# ===========================================

# PostgreSQL database connection string
DATABASE_URL=postgresql://user:password@host:5432/clawpunch

# Anthropic API key for Claude Sonnet 4.5 (powers all 8 agents)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ===========================================
# OPTIONAL — Enhanced Features
# ===========================================

# CoinGecko API key (Pro tier removes rate limits for Punch Oracle & Trend Puncher)
COINGECKO_API_KEY=CG-...

# GitHub Personal Access Token (enables Repo Ape agent GitHub scanning)
GITHUB_TOKEN=ghp_...

# Solana RPC endpoint (defaults to public mainnet-beta if not set)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
